ANTHROPIC_API_KEY=your_api_key_here
DEFAULT_MODEL=claude-sonnet-4-6
MAX_STEPS=10
LOG_LEVEL=INFO
GRAPH_API_KEY=your_graph_api_key_here

# Broker / execution
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here
BROKER_MODE=dry_run

# ── Asset configuration ───────────────────────────────────────────────────────
# ASSET_CHAIN selects the data source and market.
# ASSET_TOKEN_ADDRESS is the contract address (crypto) or Yahoo Finance ticker (traditional).
# ASSET_BUCKET_SECONDS sets candle width: 3600=1h, 14400=4h, 86400=daily.
#
# ── Crypto (on-chain subgraph) ─────────────────────────────────────────────
# ASSET_CHAIN=pulsechain
# ASSET_TOKEN_ADDRESS=0x2b591e99afe9f32eaa6214f7b7629768c40eeb39   # HEX
# ASSET_BUCKET_SECONDS=14400
#
# ── Traditional markets (Yahoo Finance, no API key required) ───────────────
# Gold Futures (GC=F continuous contract, full history from ~1983):
# ASSET_CHAIN=gold
# ASSET_TOKEN_ADDRESS=                # symbol is fixed in chain config (GC=F)
# ASSET_BUCKET_SECONDS=86400
#
# S&P 500 (SPY ETF, full history from 1993, has real volume):
# ASSET_CHAIN=spx500
# ASSET_TOKEN_ADDRESS=
# ASSET_BUCKET_SECONDS=86400
#
# S&P 500 full history (~1927, ~100 years — volume is synthetic, avoid VOLUME_ABOVE_SMA signals):
# ASSET_CHAIN=spx500_full
# ASSET_TOKEN_ADDRESS=
# ASSET_BUCKET_SECONDS=86400
#
# Nasdaq-100 (QQQ ETF, full history from 1999):
# ASSET_CHAIN=nasdaq
# ASSET_TOKEN_ADDRESS=
# ASSET_BUCKET_SECONDS=86400
#
# Any US stock or ETF (supply Yahoo Finance ticker):
# ASSET_CHAIN=stocks
# ASSET_TOKEN_ADDRESS=AAPL
# ASSET_BUCKET_SECONDS=86400
#
# Bitcoin via Yahoo Finance:
# ASSET_CHAIN=crypto_yahoo
# ASSET_TOKEN_ADDRESS=BTC-USD
# ASSET_BUCKET_SECONDS=86400

ASSET_CHAIN=pulsechain
ASSET_TOKEN_ADDRESS=0x2b591e99afe9f32eaa6214f7b7629768c40eeb39
ASSET_BUCKET_SECONDS=14400

# Local LLM support (e.g. Ollama, LM Studio, or any OpenAI-compatible endpoint)
LOCAL_LLM=false
LOCAL_LLM_MODEL=qwen3vl-30b-a3b
